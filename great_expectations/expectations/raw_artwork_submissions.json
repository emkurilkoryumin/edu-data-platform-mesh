{
  "expectation_suite_name": "raw_artwork_submissions",
  "meta": {
    "great_expectations_version": "0.18.0",
    "domain": "gallery_engagement"
  },
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": { "min_value": 1, "max_value": 10000 }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "submission_id" }
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": { "column": "submission_id" }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": { "column": "artist_id" }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": { "column": "artist_age", "min_value": 6, "max_value": 17 }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": { "column": "moderation_score", "min_value": 0, "max_value": 100 }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "technique",
        "value_set": ["watercolor", "gouache", "digital", "pencil", "acrylic", "mixed_media"]
      }
    }
  ]
}
