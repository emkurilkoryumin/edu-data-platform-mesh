PROJECT_NAME=edu-gallery-platform
ENVIRONMENT=local

# S3-compatible storage: MinIO locally, Yandex Object Storage in cloud.
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=edu-gallery-lake
S3_ACCESS_KEY=gallery
S3_SECRET_KEY=gallery-secret
S3_REGION=ru-central1

KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_PUBLIC_BOOTSTRAP_SERVERS=localhost:9092

CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=gallery
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

AIRFLOW_UID=50000
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Optional failure notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=

CUBEJS_API_SECRET=dev-secret
CUBEJS_DEV_MODE=true
CUBEJS_DB_TYPE=clickhouse
CUBEJS_DB_HOST=clickhouse
CUBEJS_DB_PORT=8123
CUBEJS_DB_NAME=gallery
CUBEJS_DB_USER=default
CUBEJS_DB_PASS=

VITE_CUBE_API_URL=http://localhost:4000/cubejs-api/v1
VITE_CUBE_TOKEN=
